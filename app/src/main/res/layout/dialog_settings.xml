<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:maxHeight="600dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Handle bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:background="@drawable/input_bg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure how etchit connects to the Autonomi network"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Bootstrap peers -->
        <LinearLayout
            android:id="@+id/p2pSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOOTSTRAP PEERS"
                android:textColor="@color/accent_blue"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/bootstrapPeersInput"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/input_selector"
                android:hint="ip:port per line, e.g. 167.172.17.218:10000"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:padding="14dp"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:gravity="top"
                android:inputType="textMultiLine" />
        </LinearLayout>

        <!-- ── Wallet Section ────────────── -->
        <LinearLayout
            android:id="@+id/walletSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WALLET"
                android:textColor="@color/accent_blue"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/connectWalletBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Connect Wallet"
                android:textColor="@color/brand_ink"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:letterSpacing="0.04"
                android:backgroundTint="@color/brand_copper" />

            <TextView
                android:id="@+id/walletStatusLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp"
                android:text="Not connected" />
        </LinearLayout>

        <!-- ── Data ────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/etchHistoryBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Etch History"
                android:textSize="13sp"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/privateEtchesBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="\uD83D\uDD12  Private Etches"
                android:textSize="13sp"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/libraryBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="\uD83D\uDCDA  Library"
                android:textSize="13sp"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewTermsBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="View Terms"
                android:textSize="13sp"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settingsCancelBtn"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Cancel"
                android:textSize="14sp"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settingsSaveBtn"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Save &amp; Reconnect"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
