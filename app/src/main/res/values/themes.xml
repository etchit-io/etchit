<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Etchit" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#c9732b</item>
        <item name="colorOnPrimary">#0a0a0a</item>
        <item name="colorPrimaryContainer">#1c1c1c</item>
        <item name="colorOnPrimaryContainer">#f5f2eb</item>
        <item name="colorSecondary">#e58a3f</item>
        <item name="colorOnSecondary">#0a0a0a</item>
        <item name="colorSecondaryContainer">#222222</item>
        <item name="colorSurface">#0a0a0a</item>
        <item name="colorSurfaceVariant">#141414</item>
        <item name="colorOnSurface">#f5f2eb</item>
        <item name="colorOnSurfaceVariant">#8a8a8a</item>
        <item name="colorOutline">#222222</item>
        <item name="colorError">#f7768e</item>
        <item name="android:statusBarColor">#050505</item>
        <item name="android:navigationBarColor">#050505</item>
        <item name="android:windowBackground">#0a0a0a</item>
    </style>

    <!-- Backwards-compat alias for any stray references still using the old name -->
    <style name="Theme.AntPaste" parent="Theme.Etchit" />

    <style name="SheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <style name="BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">#141414</item>
        <item name="shapeAppearance">@style/SheetShape</item>
    </style>

    <style name="SheetShape" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
