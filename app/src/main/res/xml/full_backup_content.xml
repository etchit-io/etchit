<?xml version="1.0" encoding="utf-8"?>
<!--
  Applies on Android < 12 (API < 31). See data_extraction_rules.xml
  for rationale. tools:replace in the manifest overrides Reown's rules,
  so we keep their WalletConnectV2.db exclusion alongside ours.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="ant_paste_secure.xml" />
    <exclude domain="database" path="WalletConnectV2.db" />
</full-backup-content>
